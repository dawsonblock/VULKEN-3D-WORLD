build CMakeFiles/ContinuousSubmit | ${cmake_ninja_workdir}CMakeFiles/ContinuousSubmit: CUSTOM_COMMAND
  COMMAND = cd /app/build_novk && /usr/bin/ctest -D ContinuousSubmit
  pool = console

# =============================================================================
# Write statements declared in CMakeLists.txt:
# /app/CMakeLists.txt
# =============================================================================

# =============================================================================
# Object build statements for EXECUTABLE target ipc_smoke_test


#############################################
# Order-only phony target for ipc_smoke_test

build cmake_object_order_depends_target_ipc_smoke_test: phony || tools/ipc_smoke_test/CMakeFiles/ipc_smoke_test.dir

build tools/ipc_smoke_test/CMakeFiles/ipc_smoke_test.dir/main.cpp.o: CXX_COMPILER__ipc_smoke_test_RelWithDebInfo /app/tools/ipc_smoke_test/main.cpp || cmake_object_order_depends_target_ipc_smoke_test
  DEP_FILE = tools/ipc_smoke_test/CMakeFiles/ipc_smoke_test.dir/main.cpp.o.d
  FLAGS = -O2 -g -DNDEBUG -fPIE -Wall -Wextra -Wpedantic -Wshadow -Wconversion -Wdouble-promotion -Wformat=2 -Wno-unused-parameter -std=gnu++20
  INCLUDES = -I/app/build_novk/generated
  OBJECT_DIR = tools/ipc_smoke_test/CMakeFiles/ipc_smoke_test.dir
  OBJECT_FILE_DIR = tools/ipc_smoke_test/CMakeFiles/ipc_smoke_test.dir
  TARGET_COMPILE_PDB = tools/ipc_smoke_test/CMakeFiles/ipc_smoke_test.dir/
  TARGET_PDB = tools/ipc_smoke_test/ipc_smoke_test.pdb


# =============================================================================
# Link build statements for EXECUTABLE target ipc_smoke_test


#############################################
# Link the executable tools/ipc_smoke_test/ipc_smoke_test

build tools/ipc_smoke_test/ipc_smoke_test: CXX_EXECUTABLE_LINKER__ipc_smoke_test_RelWithDebInfo tools/ipc_smoke_test/CMakeFiles/ipc_smoke_test.dir/main.cpp.o
  FLAGS = -O2 -g -DNDEBUG
  LINK_FLAGS = -Wl,--no-undefined
  OBJECT_DIR = tools/ipc_smoke_test/CMakeFiles/ipc_smoke_test.dir
  POST_BUILD = :
  PRE_LINK = :
  TARGET_COMPILE_PDB = tools/ipc_smoke_test/CMakeFiles/ipc_smoke_test.dir/
  TARGET_FILE = tools/ipc_smoke_test/ipc_smoke_test
  TARGET_PDB = tools/ipc_smoke_test/ipc_smoke_test.pdb


#############################################
# Utility command for test

build tools/ipc_smoke_test/CMakeFiles/test.util: CUSTOM_COMMAND
  COMMAND = cd /app/build_novk/tools/ipc_smoke_test && /usr/bin/ctest --force-new-ctest-process
  DESC = Running tests...
  pool = console
  restat = 1

build tools/ipc_smoke_test/test: phony tools/ipc_smoke_test/CMakeFiles/test.util


#############################################
# Utility command for edit_cache

build tools/ipc_smoke_test/CMakeFiles/edit_cache.util: CUSTOM_COMMAND
  COMMAND = cd /app/build_novk/tools/ipc_smoke_test && /usr/bin/cmake -E echo No\ interactive\ CMake\ dialog\ available.
  DESC = No interactive CMake dialog available...
  restat = 1

build tools/ipc_smoke_test/edit_cache: phony tools/ipc_smoke_test/CMakeFiles/edit_cache.util


#############################################
# Utility command for rebuild_cache

build tools/ipc_smoke_test/CMakeFiles/rebuild_cache.util: CUSTOM_COMMAND
  COMMAND = cd /app/build_novk/tools/ipc_smoke_test && /usr/bin/cmake --regenerate-during-build -S/app -B/app/build_novk
  DESC = Running CMake to regenerate build system...
  pool = console
  restat = 1

build tools/ipc_smoke_test/rebuild_cache: phony tools/ipc_smoke_test/CMakeFiles/rebuild_cache.util


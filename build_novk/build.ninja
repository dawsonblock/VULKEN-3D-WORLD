build CMakeFiles/ContinuousCoverage | ${cmake_ninja_workdir}CMakeFiles/ContinuousCoverage: CUSTOM_COMMAND
  COMMAND = cd /app/build_novk && /usr/bin/ctest -D ContinuousCoverage
  pool = console


#############################################
